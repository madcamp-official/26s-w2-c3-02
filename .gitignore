# Godot 4+ specific ignores
.godot/
.import/
export.cfg

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/

# System/tool-specific ignores
.DS_Store
Thumbs.db

# Oversized assets pending compression (GitHub 100MB limit) — see Docs/Plan.md
client/assets/Nest/Nest.glb

# 주의: assets/ 옆의 낱개 텍스처(nupjuk_Image_*.png, aligator_*.jpg 등)는 미사용 파일이
# 아니다. gltf/embedded_image_handling=1은 "내장"이 아니라 "Extract Textures"라서, Godot이
# glb에서 추출해 임포트된 씬이 실제로 참조하는 소스 파일들이다. 지우면 배포판에서 해당
# 모델의 텍스처가 전부 빠진다 (2026-07-14 실제로 겪음). 절대 ignore/삭제하지 말 것.
