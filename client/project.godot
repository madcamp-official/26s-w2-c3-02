; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="26s-w2-c3-02"
run/main_scene="res://scenes/boot/Boot.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://assets/ui/icons/duckwithknife.png"

[autoload]

GameData="*res://scripts/autoload/GameData.gd"
SceneRouter="*res://scripts/autoload/SceneRouter.gd"
MockServer="*res://scripts/autoload/MockServer.gd"
AudioManager="*res://scripts/autoload/AudioManager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation="sensor_landscape"

[gui]

theme/custom="res://themes/GameTheme.tres"

