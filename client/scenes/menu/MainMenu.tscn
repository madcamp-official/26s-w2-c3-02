[sub_resource type="Shader" id="Shader_icon_mask"]
code = "shader_type canvas_item;
uniform vec4 fill_color : source_color = vec4(1.0);
void fragment() {
	vec4 tex = texture(TEXTURE, UV);
	COLOR = vec4(fill_color.rgb, tex.a * fill_color.a);
}"

